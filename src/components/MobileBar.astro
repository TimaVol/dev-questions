---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<header class="mobile-bar">
	<button type="button" class="mobile-bar__btn" id="menu-toggle" aria-label="Меню" aria-expanded="false">
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<path d="M4 6h16M4 12h16M4 18h16"></path>
		</svg>
	</button>
	<p class="mobile-bar__title">{title}</p>
	<button type="button" class="mobile-bar__btn" id="toc-toggle" aria-label="Список питань" aria-expanded="false">
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"></path>
		</svg>
	</button>
</header>
<div class="drawer-backdrop" id="drawer-backdrop" hidden></div>
