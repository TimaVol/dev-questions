---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import DifficultyBadge from './DifficultyBadge.astro';

interface Props {
	entry: CollectionEntry<'questions'>;
	index: number;
}

const { entry, index } = Astro.props;
const { Content } = await render(entry);

const topicLabels: Record<string, string> = { frontend: 'Frontend', nodejs: 'Node.js' };
const gradeLabels: Record<string, string> = {
	junior: 'Junior',
	middle: 'Middle',
	senior: 'Senior',
	'middle-senior': 'Middle/Senior',
};
const pinPath = `/${entry.data.topic}/${entry.data.grade}`;
const pinLabel = `${topicLabels[entry.data.topic]} · ${gradeLabels[entry.data.grade]}`;
---

<section
	id={entry.id}
	class="question-card"
	data-difficulty={entry.data.difficulty}
	data-index={index}
>
	<header class="question-header">
		<span class="question-num" aria-hidden="true">{index}</span>
		<div class="question-title-wrap">
			<h2>{entry.data.title}</h2>
			<DifficultyBadge difficulty={entry.data.difficulty} />
		</div>
		<div class="question-actions">
			<button
				type="button"
				class="pin-btn"
				data-pin-id={entry.id}
				data-pin-path={pinPath}
				data-pin-title={entry.data.title}
				data-pin-label={pinLabel}
				data-pin-index={index}
				aria-label="Закріпити питання"
				aria-pressed="false"
			>
				📍
			</button>
			<button
				type="button"
				class="favorite-btn"
				data-favorite-id={entry.id}
				aria-label="Додати в обране"
				aria-pressed="false"
			>
				☆
			</button>
		</div>
	</header>

	<details class="answer-panel">
		<summary class="answer-toggle">Спробуй відповісти — потім відкрий</summary>
		<div class="question-body">
			<Content />
		</div>
	</details>
</section>
