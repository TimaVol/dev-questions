---
interface Props {
	page: 'topic' | 'random' | 'practice';
	variant?: 'inline' | 'panel';
	above?: boolean;
}

const { page, variant = 'inline', above = false } = Astro.props;
---

<aside
	class:list={[
		'keyboard-tips',
		variant === 'panel' && 'keyboard-tips--panel',
		variant === 'inline' && 'toolbar-hint',
		above && 'keyboard-tips--above',
	]}
	aria-label="Клавіатурні скорочення"
>
	{
		variant === 'panel' && <p class="keyboard-tips__title">Клавіші</p>
	}
	<ul class="keyboard-tips__list">
		{
			page === 'topic' ? (
				<>
					<li><kbd>J</kbd> / <kbd>K</kbd> — наступне / попереднє питання</li>
					<li><kbd>Space</kbd> — відкрити / закрити відповідь</li>
					<li><kbd>O</kbd> — відкрити або закрити всі відповіді</li>
					<li><kbd>P</kbd> — закріпити питання</li>
					<li><kbd>Esc</kbd> — скинути пошук</li>
				</>
			) : page === 'practice' ? (
				<>
					<li><kbd>Space</kbd> — відкрити / закрити відповідь</li>
					<li><kbd>1</kbd> / <kbd>2</kbd> / <kbd>3</kbd> — знав / частково / не знав</li>
					<li><kbd>P</kbd> — закріпити питання</li>
					<li class="keyboard-tips__touch">свайп вліво / вправо — знав / частково</li>
				</>
			) : (
				<>
					<li><kbd>R</kbd> — інше питання</li>
					<li><kbd>Space</kbd> — відкрити / закрити відповідь</li>
					<li><kbd>O</kbd> — відкрити або закрити всі відповіді</li>
					<li><kbd>P</kbd> — закріпити питання</li>
					<li class="keyboard-tips__desktop">подвійний клік по тексту — виділити</li>
					<li class="keyboard-tips__touch">свайп вліво / вправо — наступне питання</li>
				</>
			)
		}
	</ul>
</aside>
