---
interface Props {
	total: number;
}

const { total } = Astro.props;
---

<div class="page-toolbar">
	<div class="toolbar-row">
		<label class="search-wrap">
			<span class="visually-hidden">Пошук питань</span>
			<input
				type="search"
				id="q-search"
				class="search-input"
				placeholder="Пошук у всіх питаннях…"
				autocomplete="off"
			/>
		</label>
		<div class="filter-chips" role="group" aria-label="Фільтри">
			<button type="button" class="chip chip--active" data-difficulty-filter="all">Усі</button>
			<button type="button" class="chip" data-difficulty-filter="easy">Легкі</button>
			<button type="button" class="chip" data-difficulty-filter="medium">Середні</button>
			<button type="button" class="chip" data-difficulty-filter="hard">Складні</button>
			<button type="button" class="chip chip--favorites" data-favorites-filter aria-pressed="false">
				Обране <span id="favorites-count" class="chip-count" hidden></span>
			</button>
		</div>
	</div>
	<div class="toolbar-meta">
		<span id="toolbar-status">{total} на сторінці</span>
		<button type="button" class="pin-continue" id="open-all-answers">Відкрити всі відповіді</button>
		<a class="pin-continue" href="#" hidden data-pin-resume="short" data-pin-resume-same-page>Продовжити</a>
	</div>
</div>
